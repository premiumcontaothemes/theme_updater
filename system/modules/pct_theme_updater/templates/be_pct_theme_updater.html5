<?php elseif($this->status == 'SELF_UPDATE'): ?>
<!-- ! SELF_UPDATE screen -->
	<div class="tl_formbody_middle">
	
	<form action="<?php echo $this->action; ?>" class="tl_form" method="post">
			<input type="hidden" name="FORM_SUBMIT" value="<?= $this->formId; ?>">
			<input type="hidden" name="REQUEST_TOKEN" value="<?= $strToken ; ?>">
			<button name="self_update">Version <?= $this->online_version; ?> installieren</button>
	</form>

	<?php if( !$this->ajax_running ): ?>
	<!-- start the unzip command via ajax -->
	<?php 
	$url = StringUtil::decodeEntities( Backend::addToUrl('do=pct_theme_updater',true,array('status','step')) );
	?>
	<script>
	jQuery(document).ready(function() 
	{
		jQuery('button[name="self_update"]').click(function(e)
		{
			e.preventDefault();
			PCT_ThemeUpdater.ajax_infotext = 'Self update running';
			PCT_ThemeUpdater.request({'action':'run','redirectTo':'<?= $url; ?>'});
		});
	});
	</script>
	<?php endif; ?>

	</div>
<?php elseif($this->status == 'DONE'): ?>
<!-- ! DONE, COMPLETED screen -->
	
	<?php if($this->errors): ?>
	<div class="backend_explanation_additional error"><?= implode("\n", $this->errors); ?></div>
